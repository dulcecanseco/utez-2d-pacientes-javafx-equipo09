<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.AppController">
    <children>
        <HBox layoutX="14.0" layoutY="30.0" prefHeight="130.0" prefWidth="557.0">
            <children>
                <GridPane prefHeight="131.0" prefWidth="557.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <Label text="Nombre completo" />
                        <Label text="Edad" GridPane.rowIndex="1" />
                        <Label text="Telefono" GridPane.rowIndex="2" />
                        <Label text="CURP" GridPane.rowIndex="3" />
                        <TextField fx:id="txtNombre" GridPane.columnIndex="1" />
                        <TextField fx:id="txtEdad" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <TextField fx:id="txtTelefono" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <TextField fx:id="txtCurp" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        <Label text="Alergias" GridPane.rowIndex="4" />
                        <TextField fx:id="txtAlergias" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                    </children>
                </GridPane>
            </children>
        </HBox>
        <Label layoutX="17.0" layoutY="6.0" text="Directorio de pacientes" />

        <Button layoutX="8.0" layoutY="165.0" mnemonicParsing="false" onAction="#onAgregar" text="Agregar" />
        <Button layoutX="68.0" layoutY="165.0" mnemonicParsing="false"  onAction="#onEliminar" text="Eliminar" />
        <Button layoutX="129.0" layoutY="165.0" mnemonicParsing="false"  onAction="#onActualizar" text="Actualizar" />

        <Label fx:id="lblMsg" layoutX="210.0" layoutY="170.0" prefHeight="17.0" prefWidth="350.0" text="..." textFill="#d31010" />

        <VBox layoutX="10.0" layoutY="200.0" prefHeight="131.0" prefWidth="557.0">
            <children>
                <TableView fx:id="tblPacientes" prefHeight="131.0" prefWidth="557.0">
                    <columns>
                        <TableColumn fx:id="colNombre" prefWidth="120.0" text="Nombre" />
                        <TableColumn fx:id="colEdad" prefWidth="60.0" text="Edad" />
                        <TableColumn fx:id="colTelefono" prefWidth="100.0" text="Telefono" />
                        <TableColumn fx:id="colCurp" prefWidth="120.0" text="CURP" />
                        <TableColumn fx:id="colAlergias" prefWidth="150.0" text="Alergias" />
                    </columns>
                </TableView>
            </children>
        </VBox>

        <HBox layoutX="10.0" layoutY="340.0" prefHeight="30.0" prefWidth="557.0" spacing="20.0">
            <children>
                <Label fx:id="lblTotal" text="Total: " />
                <Label fx:id="lblActivos" text="Activos: " />
                <Label fx:id="lblInactivos" text="Inactivos: " />
            </children>
        </HBox>
    </children>
</AnchorPane>